# ============================================================
# Project Cascade — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── LLM Configuration (via LiteLLM) ─────────────────────────
# Supported: openai/gpt-4o, anthropic/claude-3-5-sonnet-20241022,
#            gemini/gemini-1.5-pro, ollama/codellama
CASCADE_LLM_MODEL=openai/gpt-4o

# API keys — only set the one matching your chosen model
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AI...

# ── Database ─────────────────────────────────────────────────
# SQLite (default for development):
CASCADE_DATABASE_URL=sqlite+aiosqlite:///~/.cascade/cascade.db

# PostgreSQL (production):
# CASCADE_DATABASE_URL=postgresql+asyncpg://cascade:password@localhost:5432/cascade

# ── Artifact Store ────────────────────────────────────────────
# local (default for development):
CASCADE_ARTIFACT_BACKEND=local
CASCADE_ARTIFACT_LOCAL_ROOT=~/.cascade/artifacts

# S3/MinIO (production):
# CASCADE_ARTIFACT_BACKEND=s3
# CASCADE_ARTIFACT_S3_BUCKET=cascade-artifacts
# CASCADE_ARTIFACT_S3_ENDPOINT_URL=http://localhost:9000   # MinIO only
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_DEFAULT_REGION=us-east-1

# ── GitHub Integration ────────────────────────────────────────
# Personal Access Token (PAT) — upgrade to GitHub App in production
GITHUB_TOKEN=ghp_...
GITHUB_DEFAULT_BASE_BRANCH=main

# ── Docker Sandbox ────────────────────────────────────────────
CASCADE_SANDBOX_IMAGE=python:3.12-slim
CASCADE_SANDBOX_MEM_LIMIT=1g
CASCADE_SANDBOX_CPU_QUOTA=100000   # 1 CPU
CASCADE_SANDBOX_TIMEOUT_SECONDS=300

# ── FastAPI Server ────────────────────────────────────────────
CASCADE_API_HOST=0.0.0.0
CASCADE_API_PORT=8000
CASCADE_API_RELOAD=true

# ── Cascade Behaviour ─────────────────────────────────────────
CASCADE_MAX_RETRIES=3
CASCADE_LOG_LEVEL=INFO
CASCADE_HOME=~/.cascade
